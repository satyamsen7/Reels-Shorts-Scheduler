# ─────────────────────────────────────────────────────────────
# REELS SCHEDULER — Environment Variables
# Copy this file to .env and fill in your real credentials
# ─────────────────────────────────────────────────────────────

PORT=3000

# ── Google Service Account (for Sheets + Drive) ──────────────
# Path to your downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# ── Google Sheets ─────────────────────────────────────────────
GS_SPREADSHEET_ID=1TjZL_eWbs01DdRYs8pJNDr5UMXzYe8u311o6rVUwjdg
GS_SHEET_NAME=Execute

# ── Instagram (Graph API v23.0) ───────────────────────────────
# Long-lived access token with instagram_content_publish scope
IG_TOKEN=EAAxxxxxxxxxxxxxxx
IG_USER_ID=17841400000000000

# ── Facebook (Page Access Token) ─────────────────────────────
FB_PAGE_ID=123456789012345
FB_PAGE_TOKEN=EAAxxxxxxxxxxxxxxx

# ── YouTube (OAuth2 with youtube.upload scope) ────────────────
YT_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
YT_CLIENT_SECRET=GOCSPX-xxxxxxxx
YT_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=my-cloud-name
CLOUDINARY_UPLOAD_PRESET=ml_default
# Optional: for signed uploads (more secure)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
